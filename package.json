{
  "name": "hibob-bug-dashboard",
  "version": "1.0.0",
  "description": "Production Bug Analytics Dashboard for HiBob",
  "main": "scripts/export/export-jira-data.js",
  "scripts": {
    "export": "node scripts/export/export-jira-data.js",
    "update-dashboard": "node update-dashboard-data.js",
    "refresh": "npm run export && npm run update-dashboard",
    "export-safe": "node scripts/export/export-safe-data.js",
    "refresh-safe": "npm run export && npm run export-safe",
    "upload-external": "node scripts/export/upload-to-external.js",
    "daily-update": "node scripts/automation/daily-auto-update.js",
    "export-multi": "node export-multi-issue-data.js",
    "export-multi-safe": "node export-multi-issue-safe-data.js",
    "multi-issue-update": "node scripts/automation/multi-issue-daily-update.js",
    "update-multi-dashboard": "./update-dashboard-data.sh --multi-issue",
    "setup-automation": "chmod +x scripts/automation/setup-daily-automation.sh && ./scripts/automation/setup-daily-automation.sh",
    "setup-multi-automation": "chmod +x scripts/automation/setup-multi-issue-automation.sh && ./scripts/automation/setup-multi-issue-automation.sh",
    "setup-combined-automation": "chmod +x scripts/automation/setup-combined-automation.sh && ./scripts/automation/setup-combined-automation.sh",
    "scheduler-start": "node scripts/automation/daily-scheduler.js start",
    "scheduler-once": "node scripts/automation/daily-scheduler.js run-once",
    "scheduler-status": "node scripts/automation/daily-scheduler.js status",
    "serve": "npx http-server -p 8080 -o bug-dashboard-embedded.html",
    "serve-safe": "npx http-server -p 8080 -o dashboard-safe-standalone.html",
    "serve-external": "npx http-server -p 8080 -o dashboard-external-data.html",
    "serve-automated": "npx http-server -p 8080 -o dashboard-automated-fixed.html",
    "serve-multi": "npx http-server . -p 8090 -o dashboard-multi-issue.html",
    "serve-with-api": "concurrently \"npx http-server -p 8081 dashboard-automated-fixed.html\" \"node api/bug-api-server.js\"",
    "serve-multi-with-api": "concurrently \"npx http-server . -p 8090 -o dashboard-multi-issue.html\" \"node api/bug-api-server.js\"",
    "start-api": "node api/bug-api-server.js",
    "build-appscript": "node appscript/build.js",
    "test-appscript": "node appscript/test-parity.js && node appscript/test-shape.js && node appscript/test-format-mdy.js && node appscript/test-incremental.js",
    "deploy-appscript": "npm run test-appscript && npm run build-appscript && cd appscript && npx clasp push && npx clasp deploy --description \"manual\"",
    "appscript-pull": "cd appscript && npx clasp pull",
    "appscript-push": "npm run build-appscript && cd appscript && npx clasp push"
  },
  "dependencies": {
    "http-server": "^14.1.1"
  },
  "devDependencies": {
    "@fontsource/archivo-black": "^5.2.8",
    "@fontsource/domine": "^5.2.8",
    "@fontsource/lato": "^5.2.7",
    "@google/clasp": "^2.4.2",
    "chart.js": "^4.5.1",
    "chartjs-plugin-datalabels": "^2.2.0",
    "concurrently": "^8.2.2",
    "sortablejs": "^1.15.7"
  },
  "author": "HiBob Team",
  "license": "MIT"
}
